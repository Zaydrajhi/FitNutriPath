<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AcceuilCoachController">

    <top>
        <VBox>
            <HBox style="-fx-background-color: #f0f0f0; -fx-padding: 10;" spacing="20" alignment="CENTER_LEFT">
                <Label text="Call : +216 71 208 354"/>
                <Label text="Email : FitNutriPath@gmail.com"/>
                <Label text="Lac 2 Av. du Yen"/>
            </HBox>

            <HBox style="-fx-background-color: #ffffff; -fx-padding: 15;" spacing="20" alignment="CENTER">
                <StackPane>
                    <Rectangle width="100" height="40" fill="#4CAF50" arcWidth="10" arcHeight="10"/>
                    <Label text="LOGO" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                </StackPane>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Button text="Tableau de Bord" style="-fx-background-color: transparent;"/>
                    <Button text="Mes Clients" style="-fx-background-color: transparent;"/>
                    <Button text="Programmes Sportifs" style="-fx-background-color: transparent;"/>
                    <Button text="Séances" style="-fx-background-color: transparent;"/>
                    <Button text="Mon Profil" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-pref-width: 200;" onAction="#handleProfil"/>
                    <Button text="Déconnexion" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-pref-width: 200;" onAction="#handleLogout"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <StackPane>
                        <Circle radius="30" fill="#4CAF50"/>
                        <Label text="USER" style="-fx-font-size: 20;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Bienvenue, Coach" style="-fx-font-weight: bold;"/>
                        <Hyperlink text="Voir mon profil"/>
                        <Hyperlink text="Se déconnecter" style="-fx-text-fill: red;" onAction="#handleLogout"/>
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="30" style="-fx-padding: 20;">
                <HBox spacing="50" alignment="CENTER" style="-fx-background-color: #f8f9fa; -fx-padding: 40;">
                    <VBox spacing="20" prefWidth="400">
                        <Label text="Tableau de Bord Coach" style="-fx-font-size: 36; -fx-font-weight: bold;"/>
                        <Label text="Gérez vos clients, créez des programmes sportifs et organisez vos séances efficacement." wrapText="true"/>
                        <Button text="Voir mes statistiques" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                    </VBox>
                    <StackPane>
                        <Rectangle width="400" height="300" fill="#cccccc"/>
                        <Label text="Image Statistiques" style="-fx-text-fill: #666666;"/>
                    </StackPane>
                </HBox>

                <HBox spacing="50" alignment="CENTER">
                    <StackPane>
                        <Rectangle width="400" height="400" fill="#e0e0e0"/>
                        <Label text="Image Clients" style="-fx-text-fill: #666666;"/>
                    </StackPane>
                    <VBox spacing="20" prefWidth="400">
                        <Label text="Mes Clients" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                        <Label text="Consultez la liste de vos clients, leurs progrès et leurs programmes sportifs personnalisés." wrapText="true"/>
                        <Button text="Gérer les clients" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                    </VBox>
                </HBox>

                <VBox spacing="30" style="-fx-background-color: #f8f9fa; -fx-padding: 40;" alignment="CENTER">
                    <Label text="Statistiques et Performances" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

                    <GridPane hgap="20" vgap="20" alignment="CENTER">
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20;" spacing="15">
                            <StackPane alignment="CENTER">
                                <Circle radius="50" fill="#4CAF50"/>
                                <Label text="CLIENTS" style="-fx-font-size: 14;"/>
                            </StackPane>
                            <Label fx:id="activeClientsLabel" text="0" style="-fx-font-weight: bold;" alignment="CENTER"/>
                            <Label text="Clients actifs" wrapText="true"/>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20;" spacing="15">
                            <StackPane alignment="CENTER">
                                <Circle radius="50" fill="#2196F3"/>
                                <Label text="SÉANCES" style="-fx-font-size: 14;"/>
                            </StackPane>
                            <Label fx:id="todaySessionsLabel" text="0" style="-fx-font-weight: bold;" alignment="CENTER"/>
                            <Label text="Séances aujourd'hui" wrapText="true"/>
                        </VBox>

                        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20;" spacing="15">
                            <StackPane alignment="CENTER">
                                <Circle radius="50" fill="#FFC107"/>
                                <Label text="PROGRAMMES" style="-fx-font-size: 14;"/>
                            </StackPane>
                            <Label fx:id="createdProgramsLabel" text="0" style="-fx-font-weight: bold;" alignment="CENTER"/>
                            <Label text="Programmes créés" wrapText="true"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox style="-fx-background-color: #333333; -fx-padding: 30;" spacing="20">
            <HBox alignment="CENTER" spacing="50">
                <StackPane>
                    <Rectangle width="100" height="40" fill="#4CAF50" arcWidth="10" arcHeight="10"/>
                    <Label text="LOGO" style="-fx-text-fill: white; -fx-font-weight: bold;" alignment="CENTER"/>
                </StackPane>

                <HBox spacing="10" alignment="CENTER">
                    <TextField promptText="Votre email" style="-fx-prompt-text-fill: #999999;"/>
                    <Button text="S'abonner" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>
            </HBox>

            <HBox alignment="TOP_CENTER" spacing="50">
                <VBox spacing="10">
                    <Label text="Adresse" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Lac 2 Av du Yen" style="-fx-text-fill: white;"/>
                    <Label text="Call +216 71 208 354" style="-fx-text-fill: white;"/>
                    <Label text="FitNutriPath@gmail.com" style="-fx-text-fill: white;"/>

                    <HBox spacing="15">
                        <Label text="FB" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                        <Label text="TW" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                        <Label text="IN" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                        <Label text="IG" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>

                <VBox spacing="10">
                    <Label text="Liens utiles" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Hyperlink text="Tableau de Bord" style="-fx-text-fill: white;"/>
                    <Hyperlink text="Mes Clients" style="-fx-text-fill: white;"/>
                    <Hyperlink text="Programmes Sportifs" style="-fx-text-fill: white;"/>
                    <Hyperlink text="Séances" style="-fx-text-fill: white;"/>
                </VBox>
            </HBox>

            <Label text="© 2023 FitNutriPath - Tous droits réservés" style="-fx-text-fill: white; -fx-alignment: CENTER;"/>
        </VBox>
    </bottom>

</BorderPane> 