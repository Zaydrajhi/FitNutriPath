<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="816.0" prefWidth="1258.0" stylesheets="dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AjouterEvenement">
    <opaqueInsets>
        <Insets top="520.0" />
    </opaqueInsets>
    <children>
        <AnchorPane prefHeight="820.0" prefWidth="1490.0">
            <children>
                <!-- Fond dégradé -->
                <Rectangle height="820.0" layoutX="-33.0" width="1523.0">
                    <fill>
                        <LinearGradient endX="0" endY="1" startX="0" startY="0">
                            <stops>
                                <Stop color="#02030A" offset="1.0" />
                            </stops>
                        </LinearGradient>
                    </fill>
                </Rectangle>
                <!-- Barre latérale -->
                <VBox fx:id="menuVBox" alignment="TOP_LEFT" layoutX="-1.0" prefHeight="792.0" prefWidth="251.0" spacing="20" style="-fx-padding: 40 0;">
                    <!-- En-tête avec logo et nom de l'application -->
                    <HBox fx:id="headerHBox" alignment="CENTER_LEFT" prefHeight="122.0" prefWidth="134.0" spacing="10" style="-fx-padding: 10;">
                        <VBox alignment="TOP_LEFT" spacing="0">
                            <ImageView fx:id="logo_menu" fitHeight="84.0" fitWidth="196.0" preserveRatio="true">
                                <image>
                                    <Image url="@images/logo.jpeg" />
                                </image>
                            </ImageView>
                            <Label fx:id="appName" prefHeight="10.0" prefWidth="10.0" styleClass="app-name" text="WTL : Way To Live" wrapText="true" />
                        </VBox>
                    </HBox>

                    <!-- Boutons du menu -->
                    <Button prefHeight="46.0" prefWidth="130.0" styleClass="menu-button" text="Liste Utilisateurs" onAction="#interfaceUser">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/profile.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnPlanSportif" prefHeight="49.0" prefWidth="131.0" styleClass="menu-button" text="Événements" onAction="#interfacePlanSportif">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/event.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnWorkouts" prefHeight="47.0" prefWidth="136.0" styleClass="menu-button" text="Rendez-vous">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/rdv.jpeg" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnForum" prefHeight="45.0" prefWidth="128.0" styleClass="menu-button" text="Plan Sportif">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/fitness.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnProduits" prefHeight="49.0" prefWidth="126.0" styleClass="menu-button" text="Produits Sportifs" onAction="#interfaceProduits">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/shopping.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                </VBox>

                <!-- Cadre rond transparent au centre -->
                <Rectangle fx:id="cadre" arcHeight="50" arcWidth="50" fill="rgba(255, 255, 255, 0.6)" height="747.0" layoutX="353.0" layoutY="34.0" stroke="#677e93" strokeWidth="2" width="1085.0" />



                <TextField fx:id="tf_titre" layoutX="612.0" layoutY="144.0" prefHeight="46.0" prefWidth="358.0" promptText="Titre" style="-fx-font-weight: bold ;-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2;" />
                <TextField fx:id="tf_desc" layoutX="612.0" layoutY="200.0" prefHeight="102.0" prefWidth="357.0" promptText="description" style="-fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2; " />
                <Label layoutX="460.0" layoutY="236.0" prefHeight="31.0" prefWidth="274.0" text="Description">
                    <font>
                        <Font name="System Bold" size="19.0" />
                    </font>
                </Label>

                <!-- Bouton pour afficher la liste des exercices -->
                <Button layoutX="834.0" layoutY="618.0" mnemonicParsing="false" onAction="#afficherEvent" prefHeight="47.0" prefWidth="250.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="Afficher la liste des évènements">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>

                <!-- Bouton pour ajouter l'exercice -->
                <Button layoutX="522.0" layoutY="618.0" mnemonicParsing="false" onAction="#AjouterEvent" prefHeight="47.0" prefWidth="267.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="Ajouter l'évènement">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>

                <Label layoutX="1036.0" layoutY="221.0" text="Image">
                    <font>
                        <Font name="System Bold" size="21.0" />
                    </font>
                </Label>
                <Button fx:id="selectImageButton" contentDisplay="CENTER" layoutX="1133.0" layoutY="245.0" mnemonicParsing="false" onAction="#ajouterImage" prefHeight="30.0" prefWidth="123.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="ajouter une image" textAlignment="CENTER">
                    <font>
                        <Font name="System Italic" size="12.0" />
                    </font>
                </Button>
                <Label layoutX="461.0" layoutY="311.0" prefHeight="28.0" prefWidth="150.0" text="Date">
                    <font>
                        <Font name="System Bold" size="19.0" />
                    </font>
                </Label>
                <Label layoutX="461.0" layoutY="152.0" prefHeight="30.0" prefWidth="136.0" text="Titre">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <Label layoutX="643.0" layoutY="50.0" prefHeight="62.0" prefWidth="382.0" text="Formulaire d'évènement  " textFill="#1b2728">
                    <font>
                        <Font name="Maiandra GD" size="30.0" />
                    </font>
                </Label>



                <!-- Contenu principal (non lié à la barre latérale) -->
                <Button fx:id="retour" contentDisplay="CENTER" layoutX="397.0" layoutY="58.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="79.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="Retourner" textAlignment="CENTER">
                    <font>
                        <Font name="System Italic" size="12.0" />
                    </font>
                </Button>
                <Label layoutX="1133.0" layoutY="200.0" text="cliquez ici pour choisir votre image">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Label layoutX="398.0" layoutY="112.0" text="Veuillez remplir tous les champs..">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <ImageView fitHeight="31.0" fitWidth="37.0" layoutX="994.0" layoutY="66.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/online-survey.png" />
                    </image>
                </ImageView>
            <DatePicker fx:id="tf_date" layoutX="613.0" layoutY="312.0" />
            <Label layoutX="461.0" layoutY="359.0" prefHeight="28.0" prefWidth="150.0" text="Lieu">
               <font>
                  <Font name="System Bold" size="19.0" />
               </font>
            </Label>
            <TextField fx:id="tf_lieu" layoutX="612.0" layoutY="350.0" prefHeight="46.0" prefWidth="358.0" promptText="Lieu" style="-fx-font-weight: bold ;-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2;" />
            <Label layoutX="454.0" layoutY="410.0" prefHeight="28.0" prefWidth="150.0" text="Statut">
               <font>
                  <Font name="System Bold" size="19.0" />
               </font>
            </Label>
            <ComboBox fx:id="tf_statut" layoutX="611.0" layoutY="411.0" prefWidth="150.0" />
            <Label layoutX="454.0" layoutY="460.0" prefHeight="28.0" prefWidth="150.0" text="Type">
               <font>
                  <Font name="System Bold" size="19.0" />
               </font>
            </Label>
            <ComboBox fx:id="tf_type" layoutX="611.0" layoutY="461.0" prefWidth="150.0" />
            <Label layoutX="416.0" layoutY="509.0" prefHeight="28.0" prefWidth="167.0" text="Nombre de Place">
               <font>
                  <Font name="System Bold" size="19.0" />
               </font>
            </Label>
            <TextField fx:id="tf_nbr_place" layoutX="606.0" layoutY="500.0" prefHeight="46.0" prefWidth="358.0" promptText="Nbr Place" style="-fx-font-weight: bold ;-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2;" />
            <Label layoutX="447.0" layoutY="563.0" prefHeight="28.0" prefWidth="150.0" text="Prix">
               <font>
                  <Font name="System Bold" size="19.0" />
               </font>
            </Label>
            <TextField fx:id="tf_prix" layoutX="606.0" layoutY="554.0" prefHeight="46.0" prefWidth="358.0" promptText="Prix" style="-fx-font-weight: bold ;-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2;" />
            <ImageView fx:id="imageView" cache="true" fitHeight="122.0" fitWidth="228.0" layoutX="1055.0" layoutY="312.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </AnchorPane>

    </children>
</AnchorPane>
