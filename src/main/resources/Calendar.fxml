<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Button?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.CalendarController"
            prefWidth="1000" prefHeight="600">

    <!-- Header : Navigation mois -->
    <top>
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 20; -fx-background-color: linear-gradient(to right, #16A085, #1ABC9C);">
            <Button text="←" fx:id="previousMonthBtn"
                    style="-fx-background-color: transparent; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-cursor: hand;" />
            <Label fx:id="monthLabel"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Button text="→" fx:id="nextMonthBtn"
                    style="-fx-background-color: transparent; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>
    </top>

    <!-- Centre : Contenu principal -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- Colonne 1 : Calendrier -->
            <VBox alignment="TOP_CENTER" spacing="15">
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0;">
                    <Label text="Dim" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                    <Label text="Lun" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                    <Label text="Mar" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                    <Label text="Mer" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                    <Label text="Jeu" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                    <Label text="Ven" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                    <Label text="Sam" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 14px;" />
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <GridPane fx:id="calendarGrid"
                              hgap="10" vgap="10"
                              style="-fx-padding: 20;">
                        <!-- Les jours seront injectés depuis le contrôleur -->
                    </GridPane>
                </ScrollPane>
            </VBox>

            <!-- Colonne 2 : Liste des rendez-vous -->
            <VBox fx:id="appointmentListContainer"
                  alignment="TOP_CENTER"
                  spacing="10"
                  style="-fx-background-color: #F9F9F9; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);"
                  prefWidth="300">
                <Label text="Rendez-vous" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #16A085;" />
                <!-- Les rendez-vous du jour sélectionné s'affichent ici dynamiquement -->
            </VBox>

        </HBox>
    </center>

</BorderPane>