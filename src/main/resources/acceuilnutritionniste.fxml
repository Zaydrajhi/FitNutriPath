<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AcceuilNutritionnisteController"
            prefHeight="800.0" prefWidth="1200.0">

    <top>
        <VBox>
            <HBox style="-fx-background-color: #f0f0f0; -fx-padding: 10;" spacing="20" alignment="CENTER_LEFT">
                <Label text="Call : +216 71 208 354"/>
                <Label text="Email : FitNutriPath@gmail.com"/>
                <Label text="Lac 2 Av. du Yen"/>
            </HBox>

            <HBox style="-fx-background-color: white; -fx-padding: 10;" spacing="20" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <StackPane>
                        <Rectangle width="100" height="40" fill="#4CAF50" arcWidth="10" arcHeight="10"/>
                        <ImageView fitHeight="40.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/logo1.jpeg"/>
                            </image>
                        </ImageView>
                    </StackPane>

                    <MenuButton fx:id="rendezVousMenu" text="Rendez-Vous" popupSide="BOTTOM" style="-fx-background-color: transparent;">
                        <items>
                            <MenuItem text="Mes  Rendez-vous" onAction="#prendreRendezVous"/>
                            <MenuItem text="Mes Regimes" onAction="#afficherMesRendezVous"/>

                        </items>
                    </MenuButton>
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <ImageView fx:id="userImageView" fitHeight="40" fitWidth="40" preserveRatio="true">
                        <Image url="@images/default_user.png"/>
                    </ImageView>
                    <VBox>
                        <Label fx:id="userNameLabel" style="-fx-font-weight: bold;"/>
                        <HBox spacing="10">
                            <Hyperlink text="Voir mon profil" onAction="#handleProfil"/>
                            <Hyperlink text="Se déconnecter" onAction="#handleLogout"/>
                        </HBox>
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 20;">
                <VBox>
                    <Label text="Tableau de Bord Nutritionniste" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                    <Label text="Gérez vos patients, créez des plans nutritionnels et organisez vos rendez-vous efficacement."
                           style="-fx-text-fill: #666;"/>
                </VBox>

                <GridPane hgap="20" vgap="20">
                    <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5;" 
                          GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Patients Actifs" style="-fx-font-weight: bold;"/>
                        <Label fx:id="activePatientsLabel" text="0" style="-fx-font-size: 24;"/>
                    </VBox>

                    <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5;" 
                          GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Rendez-vous Aujourd'hui" style="-fx-font-weight: bold;"/>
                        <Label fx:id="todayAppointmentsLabel" text="0" style="-fx-font-size: 24;"/>
                    </VBox>

                    <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5;" 
                          GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <Label text="Plans Créés" style="-fx-font-weight: bold;"/>
                        <Label fx:id="createdPlansLabel" text="0" style="-fx-font-size: 24;"/>
                    </VBox>
                </GridPane>

                <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5;">
                    <Label text="Rendez-vous Récents" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                    <TableView fx:id="recentAppointmentsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Patient"/>
                            <TableColumn text="Date"/>
                            <TableColumn text="Heure"/>
                            <TableColumn text="Statut"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox style="-fx-background-color: #333333; -fx-padding: 30;" spacing="20">
            <HBox alignment="CENTER" spacing="50">
                <StackPane>
                    <Rectangle width="100" height="40" fill="#4CAF50" arcWidth="10" arcHeight="10"/>
                    <ImageView fitHeight="40.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@images/logo1.jpeg"/>
                        </image>
                    </ImageView>
                </StackPane>

                <HBox spacing="10" alignment="CENTER">
                    <TextField promptText="Votre email" style="-fx-prompt-text-fill: #999999;"/>
                    <Button text="S'abonner" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>
            </HBox>

            <HBox alignment="TOP_CENTER" spacing="50">
                <VBox spacing="10">
                    <Label text="Adresse" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Lac 2 Av du Yen" style="-fx-text-fill: white;"/>
                    <Label text="Call +216 71 208 354" style="-fx-text-fill: white;"/>
                    <Label text="FitNutriPath@gmail.com" style="-fx-text-fill: white;"/>

                    <HBox spacing="15">
                        <Label text="FB" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                        <Label text="TW" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                        <Label text="IN" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                        <Label text="IG" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>

                <VBox spacing="10">
                    <Label text="Liens utiles" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Hyperlink text="Tableau de Bord" style="-fx-text-fill: white;"/>
                    <Hyperlink text="Mes Patients" style="-fx-text-fill: white;"/>
                    <Hyperlink text="Plans Nutritionnels" style="-fx-text-fill: white;"/>
                    <Hyperlink text="Rendez-vous" style="-fx-text-fill: white;"/>
                </VBox>
            </HBox>

            <Label text="© 2023 FitNutriPath - Tous droits réservés" style="-fx-text-fill: white; -fx-alignment: CENTER;"/>
        </VBox>
    </bottom>

</BorderPane> 