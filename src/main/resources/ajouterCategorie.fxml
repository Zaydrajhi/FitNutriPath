<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="816.0" prefWidth="1258.0" stylesheets="dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AjouterCategorieController">
    <opaqueInsets>
        <Insets top="520.0" />
    </opaqueInsets>
    <children>
        <AnchorPane prefHeight="820.0" prefWidth="1490.0">
            <children>
                <!-- Fond dégradé -->
                <Rectangle height="820.0" layoutX="-33.0" width="1523.0">
                    <fill>
                        <LinearGradient endX="0" endY="1" startX="0" startY="0">
                            <stops>
                                <Stop color="#02030A" offset="1.0" />
                            </stops>
                        </LinearGradient>
                    </fill>
                </Rectangle>
                <!-- Barre latérale -->
                <VBox fx:id="menuVBox" alignment="TOP_LEFT" layoutX="-1.0" prefHeight="792.0" prefWidth="251.0" spacing="20" style="-fx-padding: 40 0;">
                    <!-- En-tête avec logo et nom de l'application -->
                    <HBox fx:id="headerHBox" alignment="CENTER_LEFT" prefHeight="122.0" prefWidth="134.0" spacing="10" style="-fx-padding: 10;">
                        <VBox alignment="TOP_LEFT" spacing="0">
                            <ImageView fx:id="logo_menu" fitHeight="84.0" fitWidth="196.0" preserveRatio="true">
                                <image>
                                    <Image url="@images/logo.jpeg" />
                                </image>
                            </ImageView>
                            <Label fx:id="appName" prefHeight="10.0" prefWidth="10.0" styleClass="app-name" text="WTL : Way To Live" wrapText="true" />
                        </VBox>
                    </HBox>

                    <!-- Boutons du menu -->
                    <Button onAction="#interfaceUser" prefHeight="46.0" prefWidth="136.0" styleClass="menu-button" text="Liste Utilisateurs">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/profile.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnEvenements" prefHeight="50.0" prefWidth="136.0" styleClass="menu-button" text="Événements">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/event.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnWorkouts" prefHeight="47.0" prefWidth="136.0" styleClass="menu-button" text="Rendez-vous">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/rdv.jpeg" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnForum" prefHeight="46.0" prefWidth="136.0" styleClass="menu-button" text="Plan Sportif">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/fitness.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnProduits" prefHeight="46.0" prefWidth="136.0" styleClass="menu-button" text="Produits Sportifs">
                        <graphic>
                            <ImageView fitHeight="20.0" fitWidth="20.0">
                                <image>
                                    <Image url="@images/shopping.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                </VBox>

                <!-- Cadre rond transparent au centre -->
                <Rectangle arcHeight="50" arcWidth="50" fill="rgba(255, 255, 255, 0.6)" height="747.0" layoutX="353.0" layoutY="34.0" stroke="#677e93" strokeWidth="2" width="1085.0" />



                <TextField fx:id="tf_nomCategorie" layoutX="689.0" layoutY="233.0" prefHeight="46.0" prefWidth="358.0" promptText=" Nom du Categorie" style="-fx-font-weight: bold ;-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2;" />
                <TextField fx:id="tf_descCat" layoutX="690.0" layoutY="333.0" prefHeight="102.0" prefWidth="357.0" promptText="description..." style="-fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2; " />
                <Label layoutX="506.0" layoutY="333.0" prefHeight="31.0" prefWidth="237.0" text="Description :">
                    <font>
                        <Font name="System Bold" size="19.0" />
                    </font>
                </Label>

                <!-- Bouton pour afficher la liste des exercices -->
                <Button layoutX="869.0" layoutY="560.0" mnemonicParsing="false" onAction="#listeCat" prefHeight="47.0" prefWidth="250.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="Liste des Categories">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>

                <!-- Bouton pour ajouter l'exercice -->
                <Button layoutX="547.0" layoutY="560.0" mnemonicParsing="false" onAction="#ajouterCat" prefHeight="47.0" prefWidth="267.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="Ajouter ">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>

                <Label layoutX="501.0" layoutY="474.0" text="Image :">
                    <font>
                        <Font name="System Bold" size="21.0" />
                    </font>
                </Label>
                <Button contentDisplay="CENTER" layoutX="619.0" layoutY="505.0" mnemonicParsing="false" onAction="#selectImage" prefHeight="30.0" prefWidth="123.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="ajouter une image" textAlignment="CENTER">
                    <font>
                        <Font name="System Italic" size="12.0" />
                    </font>
                </Button>
                <ImageView fx:id="imageView" cache="true" fitHeight="84.0" fitWidth="107.0" layoutX="842.0" layoutY="455.0" pickOnBounds="true" preserveRatio="true" />
                <Label layoutX="507.0" layoutY="241.0" prefHeight="30.0" prefWidth="136.0" text="Nom :">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <Label layoutX="702.0" layoutY="50.0" prefHeight="62.0" prefWidth="334.0" text="Ajouter Un Categorie" textFill="#1b2728">
                    <font>
                        <Font name="Maiandra GD" size="30.0" />
                    </font>
                </Label>



                <!-- Contenu principal (non lié à la barre latérale) -->
                <Button fx:id="retour" contentDisplay="CENTER" layoutX="397.0" layoutY="58.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="79.0" style="-fx-background-color: #00c6a9 ; -fx-font-weight: bold; -fx-text-fill: black; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.5), 5, 0.5, 0, 2);" text="Retourner" textAlignment="CENTER">
                    <font>
                        <Font name="System Italic" size="12.0" />
                    </font>
                </Button>
                <Label layoutX="588.0" layoutY="480.0" text="cliquez ici pour choisir votre image">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Label layoutX="408.0" layoutY="131.0" text="Veuillez remplir tous les champs..">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <ImageView fitHeight="31.0" fitWidth="37.0" layoutX="1005.0" layoutY="66.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/online-survey.png" />
                    </image>
                </ImageView>
            </children>
        </AnchorPane>

    </children>
</AnchorPane>
