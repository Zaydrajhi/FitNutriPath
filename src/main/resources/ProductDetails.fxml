<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ProductDetailsController">
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">
            <HBox alignment="CENTER" spacing="30">
                <!-- Image du produit -->
                <ImageView fx:id="productImage" fitHeight="200" fitWidth="200" preserveRatio="true"/>

                <VBox spacing="10" minWidth="250">
                    <Label fx:id="productName" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    <Label fx:id="productPrice" style="-fx-text-fill: #00c6a9; -fx-font-size: 18;"/>
                    <Label fx:id="productStock" style="-fx-font-size: 14;"/>

                    <Text fx:id="productDescription" style="-fx-font-size: 14;"
                          wrappingWidth="250"/>
                </VBox>
            </HBox>

            <!-- Formulaire de commande -->
            <GridPane hgap="10" vgap="10" style="-fx-padding: 20;">
                <Label text="Lieu de livraison:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="lieuField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Numéro de téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="numTeleField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Quantité:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Spinner fx:id="quantiteSpinner" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Total:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label fx:id="totalLabel" style="-fx-text-fill: #00c6a9; -fx-font-weight: bold;"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>

            <Button fx:id="addToCartButton" text="Ajouter au panier"
                    style="-fx-background-color: #00c6a9; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </center>
</BorderPane>