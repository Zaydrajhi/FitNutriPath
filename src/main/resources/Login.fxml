<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">

    <top>
        <VBox>
            <HBox style="-fx-background-color: #f0f0f0; -fx-padding: 10;" spacing="20" alignment="CENTER_LEFT">
                <Label text="Call : +216 71 208 354"/>
                <Label text="Email : FitNutriPath@gmail.com"/>
                <Label text="Lac 2 Av. du Yen"/>
            </HBox>

            <HBox style="-fx-background-color: white; -fx-padding: 15;" spacing="20" alignment="CENTER">
                <StackPane>
                    <Rectangle width="100" height="40" fill="#4CAF50" arcWidth="10" arcHeight="10"/>
                    <ImageView fitHeight="40.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@images/logo1.jpeg"/>
                        </image>
                    </ImageView>
                </StackPane>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <Label text="Connexion" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

            <VBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;">
                <TextField fx:id="emailField" promptText="Email" style="-fx-prompt-text-fill: #999999;"/>
                <PasswordField fx:id="passwordField" promptText="Mot de passe" style="-fx-prompt-text-fill: #999999;"/>

                <HBox alignment="CENTER">
                    <Button fx:id="loginButton" text="Se connecter" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" onAction="#handleLogin"/>
                </HBox>

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Pas de compte ?"/>
                    <Button fx:id="createAccountButton" text="Créer un compte" style="-fx-background-color: transparent; -fx-text-fill: #4CAF50;" onAction="#handleCreateAccount"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
