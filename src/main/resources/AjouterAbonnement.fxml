<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="816.0" prefWidth="1510.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AjouterAbonnement">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
                <Label text="Call : +216 71 208 354" />
                <Label text="Email : FitNutriPath@gmail.com" />
                <Label text="Lac 2 Av. du Yen" />
            </HBox>

            <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #ffffff; -fx-padding: 15;">
                <StackPane>
                    <ImageView fitHeight="40" fitWidth="100" preserveRatio="true">
                        <image>
                            <Image url="@images/logo.jpeg" />
                        </image>
                    </ImageView>
                </StackPane>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Button style="-fx-background-color: transparent;" text="Accueil" onAction="#interfaceUser" />
                    <MenuButton fx:id="rendezVousMenu" text="Rendez-Vous" popupSide="BOTTOM" style="-fx-background-color: transparent;">
                        <items>
                            <MenuItem text="Prendre Rendez-vous" onAction="#prendreRendezVous"/>
                            <MenuItem text="Mes rendez-vous" onAction="#afficherMesRendezVous"/>
                            <MenuItem text="Predict for free" onAction="#predictForFree"/>
                        </items>
                    </MenuButton>
                    <Button style="-fx-background-color: transparent;" text="Plan Sportif" />
                    <Button style="-fx-background-color: transparent;" text="Produit" onAction="#interfaceProduit" />
                    <Button style="-fx-background-color: transparent;" text="Evenement" onAction="#interfaceEvenement" />
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <StackPane>
                        <Circle fill="#4CAF50" radius="30" />
                        <Label style="-fx-font-size: 20;" text="USER" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold;" text="Bienvenue, Prénom" />
                        <Hyperlink text="Voir mon profil" />
                        <Hyperlink style="-fx-text-fill: red;" text="Se déconnecter" />
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true">
            <StackPane alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom, #00c6a9, #677e93);">
                <VBox alignment="CENTER" spacing="30" style="-fx-padding: 40; -fx-max-width: 600px;">
                    <Label text="Abonnement" textFill="#1b2728">
                        <font>
                            <Font name="Maiandra GD" size="27.0" />
                        </font>
                    </Label>

                    <Label text="Veuillez remplir tous les champs..">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Salle de sport">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <ComboBox fx:id="cb_salleDeSport" prefHeight="39.0" prefWidth="322.0" promptText="Sélectionnez une salle" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #677e93; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Nom">
                            <font>
                                <Font name="System Bold" size="17.0" />
                            </font>
                        </Label>
                        <TextField fx:id="tf_nom" prefHeight="39.0" prefWidth="322.0" promptText="Nom" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #00c6a9; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Prénom">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TextField fx:id="tf_prenom" prefHeight="39.0" prefWidth="322.0" promptText="Prénom" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #00c6a9; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Téléphone">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TextField fx:id="tf_telephone" prefHeight="39.0" prefWidth="322.0" promptText="Numéro de téléphone" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #00c6a9; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Email">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TextField fx:id="tf_email" prefHeight="39.0" prefWidth="322.0" promptText="Email" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #00c6a9; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Date Début">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <DatePicker fx:id="tf_dateDebut" prefHeight="39.0" prefWidth="322.0" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #00c6a9; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Label text="Date Fin">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <DatePicker fx:id="tf_dateFin" prefHeight="39.0" prefWidth="322.0" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10; -fx-border-color: #00c6a9; -fx-border-width: 2;" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                        <Button fx:id="btn_ajouter" onAction="#ajouterAbonnement" prefHeight="30.0" prefWidth="214.0" style="-fx-background-color: #00c6a9;" text="Ajouter Abonnement">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                        <Button fx:id="afficher" onAction="#afficherAbonnements" prefHeight="30.0" prefWidth="250.0" style="-fx-background-color: #00c6a9;" text="Liste des abonnements">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10" />
                </VBox>
            </StackPane>
        </ScrollPane>
    </center>

</BorderPane>
