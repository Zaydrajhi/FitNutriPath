<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RendezVousCard">

    <VBox alignment="CENTER" spacing="15" style="-fx-background-color: linear-gradient(to bottom, #00c6a9, #677e93); -fx-padding: 25px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

        <!-- Header with status indicator -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Circle fx:id="statusIndicator" radius="8" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Fiche Rendez-vous" />
        </HBox>

        <!-- Patient Info Section -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f5f5f5; -fx-padding: 10px; -fx-background-radius: 5px;">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #4CAF50;" text="Patient:" />
            <Label fx:id="rdvNom" style="-fx-text-fill: #333; -fx-font-weight: bold;" />
            <Label fx:id="rdvPrenom" style="-fx-text-fill: #333; -fx-font-weight: bold;" />
        </HBox>

        <!-- RendezVous Info Grid -->
        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints prefWidth="150" />
                <ColumnConstraints prefWidth="150" />
            </columnConstraints>

            <!-- Row 1 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Date/Heure:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="rdvDateHeure" style="-fx-text-fill: #333;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <!-- Row 2 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="rdvType" style="-fx-text-fill: #333;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <!-- Row 3 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Priorité:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Label fx:id="rdvPriorite" style="-fx-text-fill: #333;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <!-- Row 4 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Label fx:id="rdvTelephone" style="-fx-text-fill: #2196F3;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <!-- Row 5 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Taille/Poids:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="rdvTaillePoids" style="-fx-text-fill: #333;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <!-- Row 6 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="État:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <Label fx:id="rdvEtat" style="-fx-text-fill: #333;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <!-- Row 7 -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Dates:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <Label fx:id="rdvDateDebut" style="-fx-text-fill: #333;" />
                <Label style="-fx-text-fill: #999;" text="→" />
                <Label fx:id="rdvDateFin" style="-fx-text-fill: #333;" />
            </HBox>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <!-- Description Section -->
        <VBox alignment="CENTER_LEFT" maxWidth="500" spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 15px; -fx-border-radius: 8px;">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Description:" />
            <Label fx:id="rdvDescription" style="-fx-text-fill: #666; -fx-wrap-text: true;" />
        </VBox>

        <!-- Objectif Section -->
        <VBox alignment="CENTER_LEFT" maxWidth="500" spacing="5" style="-fx-background-color: #e8f5e9; -fx-padding: 15px; -fx-border-radius: 8px;">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #4CAF50;" text="Objectif:" />
            <Label fx:id="rdvObjectif" style="-fx-text-fill: #2e7d32; -fx-wrap-text: true;" />
        </VBox>

        <!-- Action Buttons -->
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10px;">


            <Button fx:id="deleteButton" onAction="#handleDeleteButton" style="-fx-background-color: #f44336;                            -fx-text-fill: white;                            -fx-font-weight: bold;                            -fx-font-size: 14px;                            -fx-padding: 8px 20px;                            -fx-background-radius: 5px;                            -fx-cursor: hand;" text="🗑️ Supprimer" />

            <Button fx:id="addRegimeButton" onAction="#handleAddRegimeButton" style="-fx-background-color: #2196F3;                            -fx-text-fill: white;                            -fx-font-weight: bold;                            -fx-font-size: 14px;                            -fx-padding: 8px 20px;                            -fx-background-radius: 5px;                            -fx-cursor: hand;" text="🍎 Accepter Régime" />
        </HBox>
    </VBox>
</AnchorPane>
