<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.Ajouter">

   <children>
      <!-- Label for Nom -->
      <Label layoutX="97.0" layoutY="157.0" text="Nom" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;" />

      <!-- Label for Prenom -->
      <Label layoutX="97.0" layoutY="206.0" text="Prénom" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;" />

      <!-- TextField for Nom -->
      <TextField fx:id="txtnom" layoutX="151.0" layoutY="153.0" style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-font-size: 14px; -fx-padding: 5;" />

      <!-- TextField for Prénom -->
      <TextField fx:id="txtprenom" layoutX="151.0" layoutY="202.0" style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-font-size: 14px; -fx-padding: 5;" />

      <!-- Button to add -->
      <Button fx:id="btn" layoutX="422.0" layoutY="254.0" mnemonicParsing="false" onAction="#ajouter" text="Ajouter"
              style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px;" />

      <!-- Button to navigate to Accueil -->
      <Button fx:id="btnAccueil" text="Retour à l'accueil" onAction="#naviguerVersAccueil"
              style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px;" layoutX="422.0" layoutY="294.0" />
   </children>
</AnchorPane>
