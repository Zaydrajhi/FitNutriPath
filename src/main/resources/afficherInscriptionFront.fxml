<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="816.0" prefWidth="1510.0" stylesheets="/workout.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.afficherInscription">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
                <Label text="Call : +216 71 208 354" />
                <Label text="Email : FitNutriPath@gmail.com" />
                <Label text="Lac 2 Av. du Yen" />
            </HBox>

            <HBox fx:id="headerHBox" alignment="CENTER" spacing="20" style="-fx-background-color: #ffffff; -fx-padding: 15;">
                <StackPane>
                    <ImageView fx:id="logo_menu" fitHeight="40" fitWidth="100" preserveRatio="true">
                        <image>
                            <Image url="@images/logo.jpeg" />
                        </image>
                    </ImageView>
                </StackPane>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Button fx:id="btnEvenements" style="-fx-background-color: transparent;" text="Événements" />
                    <MenuButton fx:id="btnForum" popupSide="BOTTOM" style="-fx-background-color: transparent;" text="Rendez-Vous">
                        <items>
                            <MenuItem text="Prendre Rendez-vous" />
                            <MenuItem text="Mes rendez-vous" />
                            <MenuItem text="Predict for free" />
                        </items>
                    </MenuButton>
                    <Button fx:id="btnWorkouts" style="-fx-background-color: transparent;" text="Plan Sportif" />
                    <Button fx:id="btnProduits" style="-fx-background-color: transparent;" text="Produit" />
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <StackPane>
                        <Circle fill="#4CAF50" radius="30" />
                        <Label style="-fx-font-size: 20;" text="USER's USER" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold;" text="Bienvenue, Prénom" />
                        <Hyperlink text="Voir mon profil" />
                        <Hyperlink style="-fx-text-fill: red;" text="Se déconnecter" />
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox alignment="CENTER" spacing="30" style="-fx-padding: 20; -fx-background-color: linear-gradient(to bottom, #00c6a9, #677e93);">
                <!-- Centrer le titre "Liste des Inscriptions" -->
                <HBox alignment="CENTER" prefWidth="1510.0">
                    <Text style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: white;" text="Liste des Inscriptions" />
                </HBox>

                <!-- Conteneur pour le bouton Retourner et le ListView -->
                <VBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20;">
                    <!-- Bouton Retourner avec icône de flèche -->
                    <Button fx:id="btnRetourner" onAction="#retourner" style="-fx-background-color: #00c6a9; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-border-radius: 5; -fx-padding: 5 10 5 10;" text="⬅ Retourner" />

                    <!-- Conteneur pour le ListView avec un style professionnel -->
                    <VBox fx:id="detailsContainer" spacing="10" style="-fx-padding: 20; -fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #cccccc; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0.3, 0, 4);">
                        <!-- En-tête pour simuler les colonnes -->
                        <HBox spacing="10" style="-fx-background-color: #00c6a9; -fx-padding: 12; -fx-background-radius: 5 5 0 0; -fx-border-radius: 5 5 0 0; -fx-border-color: #cccccc; -fx-border-width: 1;">
                            <Label text="🎉 Événement" prefWidth="250" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            <Label text="📅 Date" prefWidth="150" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            <Label text="💬 Commentaire" prefWidth="200" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            <Label text="👥 Places Réservées" prefWidth="150" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            <Label text="🏷️ Type" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            <Label text="⚙️ Actions" prefWidth="150" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                        </HBox>
                        <ListView fx:id="listeInscription" prefHeight="500" prefWidth="1200" style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-width: 0 1 1 1; -fx-border-radius: 0 0 5 5;" />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>